{
  "name": "forge-agent",
  "version": "0.0.1",
  "description": "Open-source vertical AI marketing agent",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "forge:onboard": "tsx scripts/onboard.ts",
    "forge:client:add": "tsx scripts/add-client.ts",
    "forge:reviews:import": "tsx scripts/import-google-reviews.ts",
    "forge:reviews:publish": "tsx scripts/publish-review-reply.ts",
    "forge:image:generate": "tsx scripts/generate-post-image.ts",
    "forge:seed": "tsx scripts/add-client.ts examples/acme-coffee.json",
    "forge:run": "tsx scripts/run.ts",
    "forge:serve": "tsx src/inngest/server.ts",
    "test": "node --import tsx --test src/forge/*.test.ts src/forge/tools/*.test.ts src/lib/admin/*.test.ts src/lib/onboarding/*.test.ts src/lib/portal/*.test.ts src/lib/reviews/*.test.ts src/lib/billing/*.test.ts",
    "typecheck": "tsc --noEmit",
    "env:validate": "node scripts/validate-env.mjs",
    "launch:status": "node .ops/launch-status.mjs",
    "launch:validate": "node scripts/validate-launch-board.mjs",
    "launch:onboarding:e2e": "node --import tsx scripts/verify-onboarding-e2e.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.74",
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@supabase/supabase-js": "^2.108.2",
    "ai": "^6.0.209",
    "dotenv": "^17.4.2",
    "inngest": "^4.9.0",
    "next": "15.5.20",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "autoprefixer": "^10.4.20",
    "postcss": "8.5.16",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "private": true,
  "type": "module"
}

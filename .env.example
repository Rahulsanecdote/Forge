# --- Model provider --------------------------------------------------
# One of: anthropic | openai | google | openai-compatible
FORGE_PROVIDER=anthropic
# Optional — defaults sensibly per provider if unset
# FORGE_MODEL=claude-sonnet-4-6

# Set ONLY the key matching FORGE_PROVIDER:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# For local / self-hosted models (FORGE_PROVIDER=openai-compatible).
# Works with Ollama, LM Studio, vLLM, LiteLLM, etc.
# FORGE_BASE_URL=http://localhost:11434/v1
# FORGE_MODEL=llama3.1
# FORGE_API_KEY=                       # usually not needed locally

# --- Supabase (always required) --------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # server-only — never ship to a browser

# --- Google Business Profile reviews (optional, server-only) ----------
# Account/location can be set globally here or per client in the dashboard.
# GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=123456789
# GOOGLE_BUSINESS_PROFILE_LOCATION_ID=987654321
# GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=ya29...
# For production, prefer refresh-token credentials over a short-lived access token.
# GOOGLE_BUSINESS_PROFILE_REFRESH_TOKEN=...
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...

# --- DataForSEO keyword metrics (optional, server-only) ---------------
# Enables real search volume, CPC, paid competition, search intent, and
# keyword difficulty in research_keywords.
# DATAFORSEO_LOGIN=your_dataforseo_login
# DATAFORSEO_PASSWORD=your_dataforseo_password
# DATAFORSEO_LOCATION_CODE=2840
# DATAFORSEO_LANGUAGE_CODE=en
# DATAFORSEO_INCLUDE_CLICKSTREAM=false

# --- Operator portal -------------------------------------------------
FORGE_ADMIN_PASSWORD=change-me-long-random-password

# --- Next.js site (Phase 00/01) --------------------------------------
# Public — safe to ship to the browser; RLS is the security boundary.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

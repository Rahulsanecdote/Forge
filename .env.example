# --- Model provider --------------------------------------------------
# One of: anthropic | openai | google | openai-compatible
FORGE_PROVIDER=anthropic
# Optional — defaults sensibly per provider if unset
# FORGE_MODEL=claude-sonnet-4-6

# Set ONLY the key matching FORGE_PROVIDER:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# For local / self-hosted models (FORGE_PROVIDER=openai-compatible).
# Works with Ollama, LM Studio, vLLM, LiteLLM, etc.
# FORGE_BASE_URL=http://localhost:11434/v1
# FORGE_MODEL=llama3.1
# FORGE_API_KEY=                       # usually not needed locally

# --- Supabase (always required) --------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # server-only — never ship to a browser

# --- Model provider --------------------------------------------------
# One of: anthropic | openai | google | openai-compatible
FORGE_PROVIDER=anthropic
# Optional — defaults sensibly per provider if unset
# FORGE_MODEL=claude-sonnet-4-6

# Set ONLY the key matching FORGE_PROVIDER:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# For local / self-hosted models (FORGE_PROVIDER=openai-compatible).
# Works with Ollama, LM Studio, vLLM, LiteLLM, etc.
# FORGE_BASE_URL=http://localhost:11434/v1
# FORGE_MODEL=llama3.1
# FORGE_API_KEY=                       # usually not needed locally

# --- Supabase (always required) --------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # server-only — never ship to a browser

# --- Google Business Profile reviews (optional, server-only) ----------
# Account/location can be set globally here or per client in the dashboard.
# GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=123456789
# GOOGLE_BUSINESS_PROFILE_LOCATION_ID=987654321
# GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=ya29...
# For production, prefer refresh-token credentials over a short-lived access token.
# GOOGLE_BUSINESS_PROFILE_REFRESH_TOKEN=...
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...

# --- Meta / Facebook Page publishing (optional, server-only) ----------
# Publish approved `facebook` social posts to a Facebook Page feed. The token
# needs pages_manage_posts (via a long-lived Page access token).
# META_PAGE_ID=123456789012345
# META_PAGE_ACCESS_TOKEN=EAAG...
# META_GRAPH_VERSION=v21.0            # optional; defaults to v21.0
# Instagram publishing (needs instagram_content_publish + an IG Business account
# linked to the Page; requires a generated image per post):
# INSTAGRAM_BUSINESS_ACCOUNT_ID=17841400000000000

# --- Image generation for post creatives (optional, server-only) ------
# Generate post images from the model's image_direction, stored in a public
# Supabase Storage bucket. Reuses the matching provider key below.
# FORGE_IMAGE_PROVIDER=google            # google (default) | openai
# FORGE_IMAGE_MODEL=imagen-4.0-generate-001   # or imagen-4.0-fast-generate-001 / gpt-image-1.5
# FORGE_IMAGE_BUCKET=content-images       # Supabase Storage bucket (public)
# google → GOOGLE_GENERATIVE_AI_API_KEY ; openai → OPENAI_API_KEY

# --- Review-request delivery (optional, server-only) ------------------
# Let Forge send review requests for you instead of copy/paste. Configure
# either channel (or both); unset channels fall back to manual copy links.
# Email via Resend (FORGE_REVIEW_FROM_EMAIL must be a verified sender):
# RESEND_API_KEY=re_...
# FORGE_REVIEW_FROM_EMAIL=reviews@yourdomain.com
# SMS via Twilio (FROM must be an SMS-capable E.164 number you own):
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+12055551234

# --- DataForSEO keyword metrics (optional, server-only) ---------------
# Enables real search volume, CPC, paid competition, search intent, and
# keyword difficulty in research_keywords.
# DATAFORSEO_LOGIN=your_dataforseo_login
# DATAFORSEO_PASSWORD=your_dataforseo_password
# DATAFORSEO_LOCATION_CODE=2840
# DATAFORSEO_LANGUAGE_CODE=en
# DATAFORSEO_INCLUDE_CLICKSTREAM=false

# --- Scheduled jobs (Inngest crons) ----------------------------------
# Standard cron syntax; prefix with a timezone if needed (e.g. TZ=America/New_York ...).
# FORGE_CONTENT_CRON=0 9 * * 1          # weekly content — Mondays 09:00 UTC
# FORGE_REVIEW_CRON=0 8 * * *           # review sweep — daily 08:00 UTC
# FORGE_PUBLISH_CRON=*/15 * * * *       # scheduled publish — every 15 minutes
# FORGE_METRICS_CRON=0 */6 * * *        # refresh post metrics — every 6 hours

# --- Operator portal -------------------------------------------------
FORGE_ADMIN_PASSWORD=change-me-long-random-password

# --- Client portal (optional) ----------------------------------------
# Read-only, per-client view at /portal, reached via a signed link an operator
# copies from the client's Manage page. Signs portal links/sessions; defaults to
# FORGE_ADMIN_PASSWORD when unset. Rotate to revoke all outstanding portal links.
# FORGE_PORTAL_SECRET=change-me-another-long-random-secret

# --- Next.js site (Phase 00/01) --------------------------------------
# Public — safe to ship to the browser; RLS is the security boundary.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_APP_URL=http://localhost:3000
